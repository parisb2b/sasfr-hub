rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — tout utilisateur authentifié peut lire les profils
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Fonction helper : vérifie si l'utilisateur est admin (sécurisé si doc absent)
    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    function canAccessList(listId) {
      return get(/databases/$(database)/documents/listes_lists/$(listId)).data.createdBy == request.auth.token.email
             || request.auth.token.email in get(/databases/$(database)/documents/listes_lists/$(listId)).data.assignees;
    }

    // Lists collection
    match /listes_lists/{listId} {
      // Création : tout utilisateur authentifié peut créer une liste
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.token.email;

      // Lecture : créateur OU assigné OU admin
      allow read: if request.auth != null
                  && (
                    resource.data.createdBy == request.auth.token.email
                    || request.auth.token.email in resource.data.assignees
                    || isAdmin()
                  );

      // Écriture : créateur OU admin (pour archiver, modifier nom, etc.)
      allow update: if request.auth != null
                    && (
                      resource.data.createdBy == request.auth.token.email
                      || isAdmin()
                    );

      // Suppression : admin uniquement (suppression définitive depuis la corbeille)
      allow delete: if request.auth != null && isAdmin();
    }

    // Tasks subcollection — hérite de la visibilité de la liste parente
    match /listes_lists/{listId}/tasks/{taskId} {
      // Création : assigné OU créateur de la liste parente OU admin
      allow create: if request.auth != null
                    && (canAccessList(listId) || isAdmin());

      // Lecture : même règles que la liste parente
      allow read: if request.auth != null
                  && (canAccessList(listId) || isAdmin());

      // Écriture : assigné OU créateur de la liste parente OU admin
      allow update: if request.auth != null
                    && (canAccessList(listId) || isAdmin());

      // Suppression : créateur de la liste parente OU admin
      allow delete: if request.auth != null
                    && (
                      get(/databases/$(database)/documents/listes_lists/$(listId)).data.createdBy == request.auth.token.email
                      || isAdmin()
                    );
    }
  }
}
